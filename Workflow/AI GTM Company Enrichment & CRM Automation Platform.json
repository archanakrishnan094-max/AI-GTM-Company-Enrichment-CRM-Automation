    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (let i = 0; i < items.length; i++) {\n\n  let raw = items[i].json.text;\n\n  // Remove markdown if present\n  raw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\n  // Convert text into JSON\n  const data = JSON.parse(raw);\n\n  const processItem = $('🔁 Process Companies').all()[i].json;\n  results.push({\n    json: {\n      company_name: data.company_name || processItem[\"Company Name\"] || \"\",\n      website: data.website || processItem[\"New column(3)\"] || \"\",\n      industry: data.industry || processItem[\"Industry\"] || \"\",\n      work_email: data.work_email || processItem[\"Work Email\"] || \"\",\n\n      business_summary: data.business_summary || processItem[\"Company Summary\"] || \"\",\n      target_customers: data.target_customers || \"\",\n      products_services: data.products_services || \"\",\n      pain_points: data.pain_points || \"\",\n      opportunities: data.opportunities || processItem[\"AI Automation Opportunities\"] || \"\",\n      recommended_solution: data.recommended_solution || \"\",\n\n      crm_stage: data.crm_stage || \"New Lead\",\n      lead_score: data.lead_score || sheetItem[\"Lead Score\"] || \"\",\n      priority: data.priority || \"\",\n\n      personalized_email_opening: data.personalized_email_opening || processItem[\"Personalized Email Opener\"] || \"\",\n      cold_email_subject: data.cold_email_subject || \"\",\n      cold_email_draft: data.cold_email_draft || processItem[\"Cold email draft\"] || \"\"\n    }\n  });\n\n}\n\nreturn results;\n"
      },
